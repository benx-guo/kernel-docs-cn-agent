#!/usr/bin/env python3
"""kt-send-patch — Send translation patches via email.

Usage:
    kt-send-patch <--self | --review [EMAIL] | --submit> [--confirm] [--dry-run] [--in-reply-to ID] [--series ID] [--json]

Options:
    --self               Send to yourself for testing
    --review [EMAIL]     Send to internal reviewer (auto-detects from previous round)
    --submit             Show git send-email command for upstream (manual only)
    --confirm            Confirm and actually send (required for --review)
    --dry-run            Dry-run only (don't actually send)
    --in-reply-to ID     Thread patches under a previous message
    --series ID          Read metadata from series-state
    --json               Output JSON
"""

import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.project import root, kernel_dir, outgoing_dir, series_state_path, config_dir
from lib.git_helpers import user_email, series_id_from_branch, is_work_branch
from lib.patch import run_get_maintainer
from lib.state import load_series_state, get_series, add_round


def find_patches(series_id=None, phase=None):
    """Find patch files in outgoing/.

    Looks in ``outgoing/<series_id>/<phase>/v<latest>/`` first,
    falls back to ``outgoing/<series_id>/v<latest>/``,
    then ``outgoing/<series_id>/*.patch``,
    then ``outgoing/*.patch``.
    """
    od = outgoing_dir()
    if series_id:
        series_dir = od / series_id
        if series_dir.is_dir():
            # Determine search root: phase subdir if available
            if phase and (series_dir / phase).is_dir():
                search_root = series_dir / phase
            else:
                search_root = series_dir
            # Find latest version subdirectory
            ver_dirs = sorted(
                [d for d in search_root.iterdir()
                 if d.is_dir() and d.name.startswith("v") and d.name[1:].isdigit()],
                key=lambda d: int(d.name[1:]),
            )
            if ver_dirs:
                return sorted(ver_dirs[-1].glob("*.patch"))
            # Fallback: flat patches in search root
            return sorted(search_root.glob("*.patch"))
    # Fallback: flat outgoing/*.patch
    if not od.is_dir():
        return []
    return sorted(od.glob("*.patch"))


def load_email_conf():
    """Load email.conf if it exists."""
    conf = config_dir() / "email.conf"
    if not conf.is_file():
        return {}
    result = {}
    for line in conf.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            k, v = line.split("=", 1)
            result[k.strip()] = v.strip()
    return result


def send_email(to_list, cc_list, patches, dry_run=False, in_reply_to=None,
               suppress_cc=False):
    """Build and run git send-email command. Returns (returncode, stdout, stderr)."""
    cmd = ["git", "send-email"]
    for addr in to_list:
        cmd += [f"--to={addr}"]
    for addr in cc_list:
        cmd += [f"--cc={addr}"]
    cmd += ["--confirm=never"]
    if suppress_cc:
        cmd += ["--suppress-cc=all"]
    if dry_run:
        cmd += ["--dry-run"]
    if in_reply_to:
        # Normalize message-id
        mid = in_reply_to.strip("<>")
        cmd += [f"--in-reply-to=<{mid}>"]
    cmd += [str(p) for p in patches]

    r = subprocess.run(cmd, cwd=kernel_dir(), capture_output=True, text=True)
    return r.returncode, r.stdout, r.stderr


def lookup_prev_recipients(series_id):
    """Look up To/Cc from the previous round's cover letter via local notmuch."""
    if not shutil.which("notmuch"):
        return None, None
    s = get_series(series_state_path(), series_id)
    if not s:
        return None, None
    # Find the cover message-id from the last sent round
    cover_mid = None
    for pk in ("upstream", "internal_review"):
        rounds = s["phases"].get(pk, {}).get("rounds", [])
        if rounds:
            cover_mid = rounds[-1].get("cover_message_id")
            break
    if not cover_mid:
        return None, None
    # Query notmuch for headers
    r = subprocess.run(
        ["notmuch", "show", "--format=json", f"id:{cover_mid}"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return None, None
    import json as _json
    try:
        data = _json.loads(r.stdout)
    except _json.JSONDecodeError:
        return None, None
    # Walk to find headers
    def find_headers(obj):
        if isinstance(obj, dict):
            h = obj.get("headers", {})
            if h.get("To") or h.get("Cc"):
                return h
        if isinstance(obj, list):
            for item in obj:
                found = find_headers(item)
                if found:
                    return found
        return None
    hdrs = find_headers(data)
    if not hdrs:
        return None, None
    to_raw = hdrs.get("To", "")
    cc_raw = hdrs.get("Cc", "")
    to_list = [a.strip() for a in to_raw.split(",") if a.strip()] if to_raw else []
    cc_list = [a.strip() for a in cc_raw.split(",") if a.strip()] if cc_raw else []
    return to_list, cc_list


def extract_message_id(output):
    """Extract Message-ID from git send-email output."""
    for line in output.splitlines():
        m = re.search(r"Message-ID:\s*<([^>]+)>", line, re.IGNORECASE)
        if m:
            return m.group(1)
    return ""


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip()); return
    use_json = "--json" in args
    dry_run = "--dry-run" in args
    series_id = None
    in_reply_to = None

    if "--series" in args:
        idx = args.index("--series")
        series_id = args[idx + 1] if idx + 1 < len(args) else None

    # Auto-detect series from current branch
    if not series_id and is_work_branch():
        series_id = series_id_from_branch()

    if "--in-reply-to" in args:
        idx = args.index("--in-reply-to")
        in_reply_to = args[idx + 1] if idx + 1 < len(args) else None

    # Read series phase for patch lookup
    phase = None
    if series_id:
        s = get_series(series_state_path(), series_id)
        if s:
            phase = s.get("phase")

    # Check prerequisites
    patches = find_patches(series_id=series_id, phase=phase)
    if not patches:
        msg = "没有补丁文件。请先运行 kt-format-patch。"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    if not shutil.which("git"):
        print("错误: git 不可用", file=sys.stderr)
        sys.exit(1)

    email = user_email()
    conf = load_email_conf()

    # Series integration — only use in-reply-to if explicitly passed via --in-reply-to.
    # Kernel convention: each version (v1, v2, ...) is an independent thread.

    # Determine mode
    mode = None
    review_email = None
    if "--self" in args:
        mode = "self"
    elif "--review" in args:
        mode = "review"
        idx = args.index("--review")
        next_arg = args[idx + 1] if idx + 1 < len(args) else None
        # next_arg is an email if it doesn't start with --
        review_email = None
        if next_arg and not next_arg.startswith("--"):
            review_email = next_arg
        elif conf.get("REVIEW_EMAIL"):
            review_email = conf["REVIEW_EMAIL"]
    elif "--submit" in args:
        mode = "submit"
    else:
        msg = "请指定模式: --self, --review EMAIL, 或 --submit"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    # Build recipient lists
    to_list = []
    cc_list = []

    if mode == "self":
        to_list = [email]
    elif mode == "review":
        if review_email:
            to_list = [review_email]
        elif series_id:
            # Auto-detect from previous round's local mail
            prev_to, prev_cc = lookup_prev_recipients(series_id)
            if prev_to:
                to_list = prev_to
                cc_list = prev_cc or []
            else:
                print("错误: 无法从上一轮邮件获取收件人，请手动指定: --review EMAIL",
                      file=sys.stderr)
                sys.exit(1)
        else:
            print("错误: --review 需要邮箱地址或 --series ID", file=sys.stderr)
            sys.exit(1)
        # Remove self from cc
        cc_list = [a for a in cc_list if email not in a]
    elif mode == "submit":
        # Collect from get_maintainer with role info
        kd = kernel_dir()
        # addr -> best role (maintainer > reviewer > open > others)
        addr_roles = {}
        ROLE_PRIORITY = {"maintainer": 0, "reviewer": 1, "open": 2,
                         "commit_signer": 3, "removed_lines": 4, "unknown": 5}
        for p in patches:
            if "0000-cover-letter" in p.name:
                continue
            entries = run_get_maintainer(p, kd)
            for e in entries:
                addr, role = e["addr"], e["role"]
                prev = addr_roles.get(addr)
                if prev is None or ROLE_PRIORITY.get(role, 9) < ROLE_PRIORITY.get(prev, 9):
                    addr_roles[addr] = role

        # To: maintainers; Cc: everyone else
        to_list = []
        cc_list = []
        for addr, role in addr_roles.items():
            # Skip self
            if email in addr:
                continue
            if role == "maintainer":
                to_list.append(addr)
            else:
                cc_list.append(addr)

    confirmed = "--confirm" in args

    result = {
        "mode": mode,
        "to": to_list,
        "cc": cc_list,
        "patches": [p.name for p in patches],
        "patch_count": len(patches),
        "in_reply_to": in_reply_to,
    }

    # Build git send-email command (used in all preview modes)
    cmd_parts = ["git", "send-email"]
    for addr in to_list:
        cmd_parts.append(f"--to='{addr}'")
    for addr in cc_list:
        cmd_parts.append(f"--cc='{addr}'")
    cmd_parts.append("--confirm=never")
    cmd_parts.append("--suppress-cc=all")
    if in_reply_to:
        mid = in_reply_to.strip("<>")
        cmd_parts.append(f"--in-reply-to='<{mid}>'")
    cmd_parts.extend(str(p) for p in patches)
    send_cmd = " \\\n    ".join(cmd_parts)
    result["command"] = " ".join(cmd_parts)

    # Preview gate: show command and exit unless --confirm (or --submit manual mode)
    needs_preview = False
    if mode == "submit":
        needs_preview = True
        result["action_required"] = "manual_submit"
    elif not confirmed and not dry_run:
        needs_preview = True
        result["action_required"] = f"confirm_{mode}"

    if needs_preview:
        headers = {
            "self": "发送预览（发给自己）",
            "review": "发送预览（内部审阅者）",
            "submit": "上游提交（需手动发送）",
        }
        if use_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"=== {headers[mode]} ===")
            print(f"  To:  {', '.join(to_list)}")
            if cc_list:
                print(f"  Cc:  {', '.join(cc_list)}")
            if in_reply_to:
                print(f"  In-Reply-To: {in_reply_to}")
            if series_id:
                print(f"  系列: {series_id}")
            print(f"\n  cd {kernel_dir()}")
            print(f"  {send_cmd}")
            if mode == "submit":
                print(f"\n请在内核目录下手动执行以上命令。")
            else:
                print(f"\n确认发送请加 --confirm 参数重新运行。")
        sys.exit(0)

    # Execute send (--self and --review --confirm only)
    is_dry = dry_run
    rc, stdout, stderr = send_email(to_list, cc_list, patches,
                                    dry_run=is_dry, in_reply_to=in_reply_to,
                                    suppress_cc=True)

    result["returncode"] = rc
    result["stdout"] = stdout
    result["stderr"] = stderr
    result["success"] = rc == 0

    # Update series state for review sends
    if rc == 0 and not is_dry and series_id and mode == "review":
        from lib.git_helpers import git_stdout
        mid = extract_message_id(stdout + stderr)
        tip = git_stdout("log", "-1", "--format=%H")
        version = add_round(series_state_path(), series_id,
                            cover_message_id=mid, tip=tip)
        result["series_version"] = version
        result["message_id"] = mid

    if use_json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        if rc == 0:
            action = "Dry-run" if is_dry else "发送"
            print(f"{action}成功！")
            print(f"  模式: {mode}")
            print(f"  收件人: {', '.join(to_list)}")
            if cc_list:
                print(f"  Cc: {', '.join(cc_list)}")
            print(f"  补丁: {len(patches)} 个")
        else:
            print(f"发送失败 (exit {rc})", file=sys.stderr)
            if stderr:
                print(stderr, file=sys.stderr)
            sys.exit(1)


if __name__ == "__main__":
    main()
