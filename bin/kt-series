#!/usr/bin/env python3
"""kt-series — Patch series lifecycle management.

Usage:
    kt-series [--list | --show ID | --create | --delete ID | --advance ID | --diff ID | --current | --dashboard | --check-feedback [ID]] [--json]

Options:
    --list              List active series (default)
    --show ID           Show detailed status for a series
    --create            Create a new series from current commits
    --delete ID         Delete a series and its work branch
    --advance ID        Advance series to the next phase
    --diff ID           Show range-diff between current and previous version
    --current           Show status of the series on the current branch
    --dashboard         Show full dashboard view
    --check-feedback    Check for replies to the latest round (auto-detects series from branch)
    --json              Output JSON
"""

import json
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.project import kernel_dir, outgoing_dir, series_state_path
from lib.git_helpers import (
    git, git_lines, git_stdout, current_branch, branch_exists, create_branch,
    checkout, delete_branch, work_branch_name, series_id_from_branch,
    is_work_branch, is_ancestor,
)
from lib.state import (
    load_series_state, save_series_state, list_active_series,
    get_series, create_series, delete_series,
    update_series_field, update_phase_status,
)


LIFECYCLE = ["翻译", "检查", "补丁", "自审", "内审", "上游", "合并"]
PHASE_INDEX = {"internal_review": 4, "upstream": 5, "merged": 6}
STATUS_ICON = {"approved": "✅", "changes_requested": "❌", "no_feedback": "⏳"}


def do_list(use_json):
    """List active series."""
    active = list_active_series(series_state_path())
    if use_json:
        result = []
        for sid, s in active:
            phase = s["phase"]
            phase_data = s["phases"].get(phase, {})
            rounds = phase_data.get("rounds", [])
            # Count action items
            action_count = 0
            if rounds:
                for p in rounds[-1].get("per_patch", {}).values():
                    action_count += len(p.get("action_items", []))
            result.append({
                "id": sid,
                "subject": s.get("subject", ""),
                "phase": phase,
                "status": phase_data.get("status", "?"),
                "files": len(s.get("files", [])),
                "version": rounds[-1]["version"] if rounds else 0,
                "action_items": action_count,
            })
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return

    if not active:
        print("当前没有活跃的补丁系列。")
        return

    for sid, s in active:
        phase = s["phase"]
        phase_data = s["phases"].get(phase, {})
        status = phase_data.get("status", "?")
        rounds = phase_data.get("rounds", [])
        version = f"v{rounds[-1]['version']}" if rounds else "-"

        action_count = 0
        if rounds:
            for p in rounds[-1].get("per_patch", {}).values():
                action_count += len(p.get("action_items", []))

        print(f"{sid}")
        print(f"  主题: {s.get('subject', '?')}")
        if s.get("branch"):
            print(f"  分支: {s['branch']}")
        print(f"  阶段: {phase} / {status}")
        print(f"  文件: {len(s.get('files', []))} 个")
        print(f"  版本: {version}")
        if action_count:
            print(f"  待处理: {action_count} 个 action items")
        print()


def do_show(series_id, use_json):
    """Show detailed status for a series."""
    s = get_series(series_state_path(), series_id)
    if not s:
        msg = f"系列 '{series_id}' 不存在"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    if use_json:
        print(json.dumps({"id": series_id, **s}, indent=2, ensure_ascii=False))
        return

    phase = s["phase"]
    phase_data = s["phases"].get(phase, {})
    rounds = phase_data.get("rounds", [])

    print(f"系列: {series_id}")
    print(f"主题: {s.get('subject', '?')}")
    if s.get("branch"):
        print(f"分支: {s['branch']}")
    print(f"阶段: {phase} / {phase_data.get('status', '?')}")
    print(f"文件: {', '.join(s.get('files', []))}")
    print(f"Commits: {', '.join(s.get('commits', []))}")

    if rounds:
        latest = rounds[-1]
        print(f"\n当前版本: v{latest['version']} (发送于 {latest.get('sent_at', '?')})")
        if latest.get("cover_message_id"):
            print(f"Cover Message-ID: {latest['cover_message_id']}")

        print("\n补丁状态:")
        per_patch = latest.get("per_patch", {})
        for num in sorted(per_patch.keys(), key=lambda x: int(x)):
            p = per_patch[num]
            icon = STATUS_ICON.get(p["status"], "?")
            rb = ", ".join(p.get("reviewed_by", []))
            rb_str = f"  [Reviewed-by: {rb}]" if rb else ""
            print(f"  {icon} {num}: {p['file']}  ({p['status']}){rb_str}")
            for item in p.get("action_items", []):
                print(f"      → {item}")

    # Round history
    all_rounds = []
    for pk in ("internal_review", "upstream"):
        for rd in s["phases"].get(pk, {}).get("rounds", []):
            all_rounds.append((pk, rd))

    if len(all_rounds) > 1:
        print("\n历史:")
        for pk, rd in all_rounds:
            print(f"  {pk} v{rd['version']} — {rd.get('sent_at', '?')}")


def do_create(use_json):
    """Create a new series from current commits and outgoing patches."""
    # Check for commits on current branch (or docs-next..HEAD)
    commits = git_lines("log", "--oneline", "docs-next..HEAD")

    # Extract files from commits (may be empty if creating before committing)
    files_raw = git_lines("log", "--name-only", "--format=", "docs-next..HEAD") if commits else []
    zh_files = sorted(set(
        f.replace("Documentation/translations/zh_CN/", "")
        for f in files_raw
        if f.startswith("Documentation/translations/zh_CN/") and f.endswith(".rst")
    ))

    commit_hashes = [line.split()[0] for line in commits]

    # Generate series ID
    from datetime import datetime, timezone
    subdirs = set()
    for f in zh_files:
        parts = f.split("/")
        if len(parts) > 1:
            subdirs.add(parts[0])
    subdir_name = "-".join(sorted(subdirs)) if subdirs else "misc"
    date_suffix = datetime.now(timezone.utc).strftime("%Y-%m")
    series_id = f"{subdir_name}-{date_suffix}"

    # Deduplicate: if series_id already exists, append a counter
    ss = load_series_state(series_state_path())
    existing = ss.get("series", {})
    if series_id in existing:
        counter = 2
        while f"{series_id}-{counter}" in existing:
            counter += 1
        series_id = f"{series_id}-{counter}"

    # Subject
    if len(zh_files) == 1:
        subject = f"docs/zh_CN: translate {zh_files[0]}"
    elif zh_files:
        subject = f"docs/zh_CN: update {subdir_name}/ subsystem translations"
    else:
        subject = f"docs/zh_CN: {subdir_name} translations"

    # Create work branch zh-work/<series-id> from docs-next
    branch = work_branch_name(series_id)
    if not branch_exists(branch):
        create_branch(branch, base="docs-next")

    # If current branch has commits for this module, cherry-pick them
    orig_branch = current_branch()
    if commits and orig_branch != branch:
        checkout(branch)
        for h in reversed(commit_hashes):
            from lib.git_helpers import git
            r = git("cherry-pick", h)
            if r.returncode != 0:
                # Abort failed cherry-pick and continue
                git("cherry-pick", "--abort")
        # Re-read commits on the new branch
        new_commits = git_lines("log", "--oneline", "docs-next..HEAD")
        commit_hashes = [line.split()[0] for line in new_commits]
    elif not commits:
        # No commits yet, just switch to the new branch
        checkout(branch)

    create_series(series_state_path(), series_id, subject, zh_files,
                  commit_hashes, branch=branch)

    result = {"id": series_id, "subject": subject, "files": zh_files,
              "commits": commit_hashes, "branch": branch}

    if use_json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        print(f"已创建系列: {series_id}")
        print(f"  分支: {branch}")
        print(f"  主题: {subject}")
        print(f"  文件: {len(zh_files)} 个")
        print(f"  Commits: {len(commit_hashes)} 个")


def do_delete(series_id, use_json):
    """Delete a series and its work branch."""
    s = get_series(series_state_path(), series_id)
    if not s:
        msg = f"系列 '{series_id}' 不存在"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    branch = s.get("branch")
    branch_deleted = False

    # Switch away from the branch if we're on it
    if branch and branch_exists(branch):
        cur = current_branch()
        if cur == branch:
            checkout("docs-next")
        delete_branch(branch)
        branch_deleted = True

    # Remove series from state
    delete_series(series_state_path(), series_id)

    result = {"id": series_id, "deleted": True, "branch_deleted": branch_deleted}
    if use_json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        print(f"已删除系列: {series_id}")
        if branch_deleted:
            print(f"  已删除分支: {branch}")


def do_advance(series_id, use_json):
    """Advance a series to the next phase.

    internal_review (approved) -> upstream
    upstream -> merged  (auto-detects if commits are in docs-next)
    """
    ssp = series_state_path()
    s = get_series(ssp, series_id)
    if not s:
        msg = f"系列 '{series_id}' 不存在"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    phase = s["phase"]

    if phase == "internal_review":
        # internal_review -> upstream
        phase_data = s["phases"].get("internal_review", {})
        status = phase_data.get("status", "")
        if status != "approved":
            msg = (f"内审阶段状态为 '{status}'，需要 'approved' 才能推进。"
                   if status else "内审阶段尚未开始。")
            if use_json:
                print(json.dumps({"error": msg, "phase": phase, "status": status}))
            else:
                print(msg, file=sys.stderr)
            sys.exit(1)

        update_series_field(ssp, series_id, phase="upstream")
        update_phase_status(ssp, series_id, "upstream", "pending")

        result = {"id": series_id, "action": "advance",
                  "from": "internal_review", "to": "upstream"}
        if use_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"已推进: {series_id}")
            print(f"  internal_review → upstream")

    elif phase == "upstream":
        # upstream -> merged
        # Check if commits are in docs-next
        commits = s.get("commits", [])
        all_merged = False
        if commits:
            all_merged = all(is_ancestor(c, "docs-next") for c in commits)

        if not all_merged and commits:
            msg = "补丁尚未被 docs-next 合并。"
            if use_json:
                print(json.dumps({"error": msg, "phase": phase,
                                  "merged": False, "commits": commits}))
            else:
                print(msg, file=sys.stderr)
            sys.exit(1)

        update_series_field(ssp, series_id, phase="merged")
        update_phase_status(ssp, series_id, "upstream", "merged")

        branch = s.get("branch")
        result = {"id": series_id, "action": "advance",
                  "from": "upstream", "to": "merged",
                  "branch": branch}
        if use_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            print(f"已推进: {series_id}")
            print(f"  upstream → merged")
            if branch:
                print(f"  工作分支 {branch} 仍保留，可用 --delete {series_id} 清理")

    elif phase == "merged":
        msg = "该系列已经是 merged 状态。"
        if use_json:
            print(json.dumps({"error": msg, "phase": phase}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    else:
        msg = f"未知阶段: {phase}"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)


def do_diff(series_id, use_json):
    """Show range-diff between the last sent version and current HEAD."""
    ssp = series_state_path()
    s = get_series(ssp, series_id)
    if not s:
        msg = f"系列 '{series_id}' 不存在"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    # Find the tip (and optional base) of the last sent round
    prev_tip = None
    prev_base = None
    for phase_key in ("upstream", "internal_review"):
        rounds = s["phases"].get(phase_key, {}).get("rounds", [])
        if rounds:
            prev_tip = rounds[-1].get("tip")
            prev_base = rounds[-1].get("base")
            break

    if not prev_tip:
        msg = "没有上一版本的 tip 记录。"
        if use_json:
            print(json.dumps({"error": msg, "series_id": series_id}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    # Switch to series branch if needed
    branch = s.get("branch")
    orig_branch = current_branch()
    if branch and orig_branch != branch:
        checkout(branch)

    cur_tip = git_stdout("log", "-1", "--format=%H")

    # Build range-diff args
    # If prev round has a custom base (e.g. migrated from monolithic branch),
    # use base..tip for the left side; otherwise use docs-next..tip
    left_base = prev_base or "docs-next"
    r = git("range-diff", f"{left_base}..{prev_tip}", f"docs-next..{cur_tip}")
    range_diff = r.stdout

    # Switch back
    if branch and orig_branch != branch:
        checkout(orig_branch)

    if use_json:
        print(json.dumps({
            "series_id": series_id,
            "prev_tip": prev_tip[:12],
            "cur_tip": cur_tip[:12],
            "range_diff": range_diff,
        }, indent=2, ensure_ascii=False))
    else:
        print(f"v1..v2 range-diff:\n")
        if range_diff.strip():
            print(range_diff)
        else:
            print("无变化。")


def do_current(use_json):
    """Show status of the series on the current branch."""
    sid = series_id_from_branch()
    if not sid:
        branch = current_branch()
        msg = f"当前分支 '{branch}' 不是 zh-work/* 工作分支。"
        if use_json:
            print(json.dumps({"error": msg, "branch": branch}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    s = get_series(series_state_path(), sid)
    if not s:
        msg = f"当前分支对应的系列 '{sid}' 在 series-state 中不存在。"
        if use_json:
            print(json.dumps({"error": msg, "series_id": sid}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    phase = s["phase"]
    phase_data = s["phases"].get(phase, {})
    status = phase_data.get("status", "?")
    rounds = phase_data.get("rounds", [])

    # Count action items
    action_items = []
    if rounds:
        for num in sorted(rounds[-1].get("per_patch", {}).keys(), key=lambda x: int(x)):
            p = rounds[-1]["per_patch"][num]
            for item in p.get("action_items", []):
                action_items.append((num, p["file"], item))

    # Commit count
    commits = git_lines("log", "--oneline", "docs-next..HEAD")

    # Lifecycle bar
    idx = PHASE_INDEX.get(phase, 0)
    lifecycle_parts = []
    for i, name in enumerate(LIFECYCLE):
        if i == idx:
            lifecycle_parts.append(f"【{name}】")
        elif i < idx:
            lifecycle_parts.append(f"{name} ✓")
        else:
            lifecycle_parts.append(name)

    if use_json:
        result = {
            "series_id": sid,
            "subject": s.get("subject", ""),
            "branch": s.get("branch", ""),
            "phase": phase,
            "status": status,
            "files": s.get("files", []),
            "commits": len(commits),
            "version": rounds[-1]["version"] if rounds else 0,
            "action_items": [{"patch": n, "file": f, "item": t}
                             for n, f, t in action_items],
        }
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return

    version = f"v{rounds[-1]['version']}" if rounds else "-"
    print(f"  {sid}  {phase}/{status}  {version}  "
          f"{len(s.get('files', []))} 文件  {len(commits)} commits")
    print(f"  " + " → ".join(lifecycle_parts))
    if action_items:
        print(f"  待办 ({len(action_items)}):")
        for num, fname, item in action_items:
            print(f"    [{num}] {fname}: {item}")


def do_dashboard(use_json):
    """Show full dashboard."""
    active = list_active_series(series_state_path())

    if use_json:
        # Reuse list format with full data
        ss = load_series_state(series_state_path())
        print(json.dumps(ss, indent=2, ensure_ascii=False))
        return

    if not active:
        print("当前没有活跃的补丁系列。用 kt-series --create 创建新系列。")
        return

    for i, (sid, s) in enumerate(active):
        if i > 0:
            print("\n---\n")

        phase = s["phase"]
        phase_data = s["phases"].get(phase, {})
        rounds = phase_data.get("rounds", [])

        print(f"## {sid}")
        print(f"**{s.get('subject', '?')}**\n")
        print(f"| 字段 | 值 |")
        print(f"|------|----|")
        print(f"| 阶段 | {phase} |")
        print(f"| 状态 | {phase_data.get('status', '?')} |")
        print(f"| 文件 | {len(s.get('files', []))} 个 |")
        if rounds:
            latest = rounds[-1]
            print(f"| 版本 | v{latest['version']}（{latest.get('sent_at', '?')}） |")
        print()

        # Patches table
        if rounds:
            latest = rounds[-1]
            per_patch = latest.get("per_patch", {})
            print("| # | 文件 | 状态 | Reviewed-by |")
            print("|---|------|------|-------------|")
            for num in sorted(per_patch.keys(), key=lambda x: int(x)):
                p = per_patch[num]
                icon = STATUS_ICON.get(p["status"], "?")
                rb = ", ".join(p.get("reviewed_by", [])) or "—"
                print(f"| {num} | {p['file']} | {icon} {p['status']} | {rb} |")
            print()

            # Action items
            items = []
            for num in sorted(per_patch.keys(), key=lambda x: int(x)):
                for item in per_patch[num].get("action_items", []):
                    items.append(f"- [ ] {item}（patch {num}）")
            if items:
                print("待办事项:")
                for item in items:
                    print(item)
                print()

        # Lifecycle bar
        idx = PHASE_INDEX.get(phase, 0)
        parts = []
        for i, name in enumerate(LIFECYCLE):
            if i == idx:
                parts.append(f"【{name}】")
            elif i < idx:
                parts.append(f"{name} ✓")
            else:
                parts.append(name)
        print(" → ".join(parts))


def do_check_feedback(series_id, use_json):
    """Check for replies to the latest round of a series."""
    # Auto-detect series from branch if not specified
    if not series_id:
        series_id = series_id_from_branch()
    if not series_id:
        branch = current_branch()
        msg = f"无法推断 series id（当前分支 '{branch}' 不是 zh-work/* 分支），请指定 ID。"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    ssp = series_state_path()
    s = get_series(ssp, series_id)
    if not s:
        msg = f"系列 '{series_id}' 不存在"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    phase = s["phase"]
    phase_data = s["phases"].get(phase, {})
    rounds = phase_data.get("rounds", [])
    if not rounds:
        msg = f"系列 '{series_id}' 在 {phase} 阶段没有发送记录。"
        if use_json:
            print(json.dumps({"error": msg, "series_id": series_id, "phase": phase}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    latest = rounds[-1]
    cover_mid = latest.get("cover_message_id", "")
    if not cover_mid:
        msg = f"系列 '{series_id}' v{latest['version']} 没有 cover_message_id。"
        if use_json:
            print(json.dumps({"error": msg, "series_id": series_id}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    # Build kt-mail --replies command based on phase
    bin_dir = Path(__file__).resolve().parent
    cmd = [sys.executable, str(bin_dir / "kt-mail"), "--replies", cover_mid, "--json"]
    if phase == "internal_review":
        cmd.append("--local")

    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        msg = f"kt-mail 失败: {r.stderr.strip()}"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    try:
        mail_result = json.loads(r.stdout)
    except json.JSONDecodeError:
        msg = f"解析 kt-mail 输出失败: {r.stdout[:200]}"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg, file=sys.stderr)
        sys.exit(1)

    replies = mail_result.get("messages", [])
    source = "本地邮箱" if phase == "internal_review" else "lore"

    if use_json:
        print(json.dumps({
            "series_id": series_id,
            "phase": phase,
            "version": latest["version"],
            "cover_message_id": cover_mid,
            "source": source,
            "replies": replies,
            "count": len(replies),
        }, indent=2, ensure_ascii=False))
    else:
        print(f"系列: {series_id}  阶段: {phase}  版本: v{latest['version']}")
        print(f"查询来源: {source}")
        print(f"Cover Message-ID: {cover_mid}")
        if not replies:
            print("\n暂无回复。")
        else:
            print(f"\n共 {len(replies)} 条回复:\n")
            for msg in replies:
                print(f"{'='*60}")
                print(f"  From:    {msg.get('from', '?')}")
                print(f"  Subject: {msg.get('subject', '?')}")
                print(f"  Date:    {msg.get('date', '?')}")
                body = msg.get("body", "").rstrip()
                lines = body.split("\n")
                if len(lines) > 80:
                    print("\n".join(lines[:80]))
                    print(f"\n... ({len(lines) - 80} more lines)")
                else:
                    print(body)
            print()


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip()); return
    use_json = "--json" in args

    if "--show" in args:
        idx = args.index("--show")
        series_id = args[idx + 1] if idx + 1 < len(args) else None
        if not series_id:
            print("错误: --show 需要系列 ID", file=sys.stderr)
            sys.exit(1)
        do_show(series_id, use_json)
    elif "--create" in args:
        do_create(use_json)
    elif "--delete" in args:
        idx = args.index("--delete")
        series_id = args[idx + 1] if idx + 1 < len(args) else None
        if not series_id:
            print("错误: --delete 需要系列 ID", file=sys.stderr)
            sys.exit(1)
        do_delete(series_id, use_json)
    elif "--advance" in args:
        idx = args.index("--advance")
        series_id = args[idx + 1] if idx + 1 < len(args) else None
        if not series_id:
            print("错误: --advance 需要系列 ID", file=sys.stderr)
            sys.exit(1)
        do_advance(series_id, use_json)
    elif "--diff" in args:
        idx = args.index("--diff")
        series_id = args[idx + 1] if idx + 1 < len(args) else None
        if not series_id:
            # Auto-detect from branch
            series_id = series_id_from_branch()
        if not series_id:
            print("错误: --diff 需要系列 ID（或在 zh-work/* 分支上运行）", file=sys.stderr)
            sys.exit(1)
        do_diff(series_id, use_json)
    elif "--current" in args:
        do_current(use_json)
    elif "--check-feedback" in args:
        idx = args.index("--check-feedback")
        # Optional series id: next arg if it exists and doesn't start with --
        series_id = None
        if idx + 1 < len(args) and not args[idx + 1].startswith("--"):
            series_id = args[idx + 1]
        do_check_feedback(series_id, use_json)
    elif "--dashboard" in args:
        do_dashboard(use_json)
    else:
        do_list(use_json)


if __name__ == "__main__":
    main()
