#!/usr/bin/env python3
"""kt-sync — Sync docs-next and manage diff cache.

Usage:
    kt-sync [--status] [--invalidate] [--json]

Options:
    --status       Show cache status without syncing
    --invalidate   Delete cache and rebuild
    --json         Output JSON
"""

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.project import kernel_dir, diff_cache_path
from lib.git_helpers import git_stdout, current_branch, docs_next_head, is_work_branch, series_id_from_branch
from lib.diff import get_status_cached


def cache_status():
    """Return cache metadata without syncing."""
    cp = diff_cache_path()
    if not cp.is_file():
        return {"cached": False}
    try:
        raw = json.loads(cp.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {"cached": False, "error": "corrupt"}
    head = docs_next_head()
    return {
        "cached": True,
        "fresh": raw.get("head") == head,
        "cache_head": raw.get("head"),
        "local_head": head,
        "created_at": raw.get("created_at"),
    }


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip()); return
    use_json = "--json" in args

    if "--status" in args:
        info = cache_status()
        if use_json:
            print(json.dumps(info, indent=2))
        else:
            if not info["cached"]:
                print("缓存: 无")
            else:
                state = "有效" if info["fresh"] else "过期"
                print(f"缓存: {state}")
                print(f"  缓存 HEAD: {info['cache_head']}")
                print(f"  本地 HEAD: {info['local_head']}")
                print(f"  创建时间: {info['created_at']}")
        return

    if "--invalidate" in args:
        cp = diff_cache_path()
        if cp.is_file():
            cp.unlink()

    # Sync: unconditionally update local docs-next to match remote
    kd = kernel_dir()
    branch = current_branch(cwd=kd)
    git_stdout("fetch", "origin", "docs-next:docs-next", cwd=kd)
    data = get_status_cached()

    if use_json:
        data["current_branch"] = branch
        if is_work_branch(branch):
            data["on_work_branch"] = True
            data["series_id"] = series_id_from_branch(branch)
        print(json.dumps(data, indent=2, ensure_ascii=False))
    else:
        print(f"同步完成  HEAD: {data['head']}")
        print(f"英文: {data['total_english']}  中文: {data['total_zh']}  覆盖率: {data['coverage']}%")
        outdated = sum(1 for f in data["files"] if f["status"] == "outdated")
        missing = len(data.get("missing", []))
        if outdated or missing:
            print(f"待更新: {outdated}  未翻译: {missing}")
        if is_work_branch(branch):
            sid = series_id_from_branch(branch)
            print(f"\n当前在工作分支: {branch} (series: {sid})")
            print(f"  继续当前工作: 直接编辑翻译文件")
            print(f"  开始新任务:   先切到 docs-next 再创建新 series")


if __name__ == "__main__":
    main()
