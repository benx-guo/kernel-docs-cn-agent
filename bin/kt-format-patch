#!/usr/bin/env python3
"""kt-format-patch — Generate formatted kernel patches.

Usage:
    kt-format-patch [--version N] [--series ID] [--json]

Options:
    --version N    Patch version (adds --reroll-count=N)
    --series ID    Read version from series-state.json
    --json         Output JSON
"""

import json
import shutil
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.project import root, kernel_dir, outgoing_dir, series_state_path
from lib.git_helpers import (
    git_lines, git_stdout, format_patch, current_branch, checkout,
    series_id_from_branch, is_work_branch, ensure_clean_worktree,
    needs_rebase, rebase_onto,
)
from lib.patch import run_checkpatch, run_get_maintainer, run_htmldocs
from lib.state import load_series_state, save_series_state


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip()); return
    use_json = "--json" in args

    version = None
    series_id = None

    if "--version" in args:
        idx = args.index("--version")
        version = int(args[idx + 1]) if idx + 1 < len(args) else None

    if "--series" in args:
        idx = args.index("--series")
        series_id = args[idx + 1] if idx + 1 < len(args) else None

    # Auto-detect series from current branch
    if not series_id and is_work_branch():
        series_id = series_id_from_branch()

    # Resolve series branch and switch if needed
    orig_branch = current_branch()
    series_branch = None
    if series_id:
        ss = load_series_state(series_state_path())
        s = ss.get("series", {}).get(series_id)
        if s:
            series_branch = s.get("branch")
            phase = s["phase"]
            rounds = s["phases"].get(phase, {}).get("rounds", [])
            if rounds:
                version = len(rounds) + 1
            elif phase == "upstream":
                version = None  # upstream v1, no reroll

    # Switch to series branch if needed
    if series_branch and current_branch() != series_branch:
        ensure_clean_worktree()
        checkout(series_branch)

    # Sync docs-next to latest, then rebase if needed
    kd = kernel_dir()
    git_stdout("fetch", "origin", "docs-next:docs-next", cwd=kd)

    rebased = False
    if needs_rebase("docs-next"):
        ensure_clean_worktree()
        rebase_onto("docs-next")
        rebased = True

    # Check for commits
    commits = git_lines("log", "--oneline", "docs-next..HEAD")
    if not commits:
        # Switch back before exiting
        if series_branch and orig_branch != series_branch:
            checkout(orig_branch)
        msg = "没有提交。请先 commit 翻译文件。"
        if use_json:
            print(json.dumps({"error": msg}))
        else:
            print(msg)
        sys.exit(1)

    # Determine output directory: outgoing/<series-id>/v<N>/ or outgoing/
    od_base = outgoing_dir()
    ver = version if version else 1
    if series_id:
        od = od_base / series_id / f"v{ver}"
    else:
        od = od_base
    if od.is_dir():
        shutil.rmtree(od)
    od.mkdir(parents=True)

    # Generate patches
    cover_letter = len(commits) > 1
    patches = format_patch(
        base="docs-next",
        output_dir=od,
        cover_letter=cover_letter,
        version=version,
    )

    # Fill cover letter subject and blurb
    if cover_letter:
        commit_subjects = git_lines("log", "--format=%s", "docs-next..HEAD")
        # Subject: from series state, or derive from commits
        cl_subject = None
        if series_id:
            ss = load_series_state(series_state_path())
            cl_subject = ss.get("series", {}).get(series_id, {}).get("subject")
        if not cl_subject:
            cl_subject = "docs/zh_CN: translate documents into Chinese"
        # Blurb: list each commit
        cl_blurb = "\n".join(f"- {s}" for s in commit_subjects) + "\n"
        for p_path in patches:
            p = Path(p_path)
            if "0000-cover-letter" not in p.name:
                continue
            text = p.read_text(encoding="utf-8")
            text = text.replace("*** SUBJECT HERE ***", cl_subject)
            text = text.replace("*** BLURB HERE ***\n", cl_blurb)
            p.write_text(text, encoding="utf-8")

    # Read patch subjects
    patch_info = []
    for p_path in patches:
        p = Path(p_path)
        subject = ""
        with open(p, encoding="utf-8") as fh:
            for line in fh:
                if line.startswith("Subject:"):
                    subject = line[len("Subject:"):].strip()
                    break
        patch_info.append({"file": p.name, "subject": subject})

    # Get maintainers
    recipients = set()
    for p_path in patches:
        p = Path(p_path)
        if "0000-cover-letter" in p.name:
            continue
        maintainers = run_get_maintainer(p, kd)
        recipients.update(maintainers)

    # Always include defaults
    recipients.add("Alex Shi <alexs@kernel.org>")
    recipients.add("linux-doc@vger.kernel.org")

    # Validate patches
    checkpatch_results = []
    for p_path in patches:
        p = Path(p_path)
        if "0000-cover-letter" in p.name:
            continue
        r = run_checkpatch(p, kd)
        checkpatch_results.append({"patch": p.name, **r})

    htmldocs_result = run_htmldocs(kd)

    # Update series-state if needed
    if series_id:
        ss = load_series_state(series_state_path())
        if series_id in ss.get("series", {}):
            commit_hashes = git_lines("log", "--format=%h", "docs-next..HEAD")
            ss["series"][series_id]["commits"] = commit_hashes
            save_series_state(series_state_path(), ss)

    # Auto-generate previous version patches if missing
    if series_id and ver > 1:
        prev_dir = od_base / series_id / f"v{ver - 1}"
        if not prev_dir.is_dir():
            ss = load_series_state(series_state_path())
            s = ss.get("series", {}).get(series_id)
            if s:
                for pk in ("upstream", "internal_review"):
                    rounds = s["phases"].get(pk, {}).get("rounds", [])
                    if rounds:
                        prev_tip = rounds[-1].get("tip")
                        prev_base = rounds[-1].get("base", "docs-next")
                        if prev_tip:
                            prev_dir.mkdir(parents=True)
                            prev_ver = rounds[-1].get("version", ver - 1)
                            format_patch(
                                base=prev_base, tip=prev_tip,
                                output_dir=prev_dir,
                                cover_letter=cover_letter,
                                version=prev_ver if prev_ver > 1 else None,
                            )
                        break

    # Switch back to original branch
    if series_branch and orig_branch != series_branch:
        checkout(orig_branch)

    output = {
        "patches": patch_info,
        "patch_count": len(patch_info),
        "cover_letter": cover_letter,
        "version": version,
        "series_id": series_id,
        "rebased": rebased,
        "recipients": sorted(recipients),
        "checkpatch": checkpatch_results,
        "htmldocs": {
            "warnings": htmldocs_result["warnings"],
            "errors": htmldocs_result["errors"],
        },
    }

    if use_json:
        print(json.dumps(output, indent=2, ensure_ascii=False))
    else:
        if rebased:
            print("✓ 已 rebase 到最新 docs-next\n")
        print(f"生成 {len(patch_info)} 个补丁:")
        for pi in patch_info:
            print(f"  {pi['file']}: {pi['subject']}")

        if series_id:
            ver_str = f"v{version}" if version else "v1"
            print(f"\n系列: {series_id} ({ver_str})")

        print(f"\n推荐收件人:")
        for r in sorted(recipients):
            print(f"  {r}")

        print(f"\n验证结果:")
        all_ok = True
        for cr in checkpatch_results:
            status = "✓" if cr["errors"] == 0 else "✗"
            print(f"  {status} {cr['patch']}: {cr['errors']}E / {cr['warnings']}W")
            if cr["errors"] > 0:
                all_ok = False

        zh_warnings = htmldocs_result["warnings"]
        zh_errors = htmldocs_result["errors"]
        if zh_errors:
            print(f"  ✗ htmldocs: {len(zh_errors)} errors")
            for e in zh_errors:
                print(f"    {e}")
            all_ok = False
        elif zh_warnings:
            print(f"  ! htmldocs: {len(zh_warnings)} warnings")
        else:
            print(f"  ✓ htmldocs: 无 zh_CN 相关问题")

        if all_ok:
            if version and version > 1 and series_id:
                print(f"\n全部通过。发送前可查看版本差异: kt-series --diff {series_id}")
            else:
                print("\n全部通过。建议下一步: kt-send-patch --self")
        else:
            print("\n有错误需要修复后重新生成。")
            sys.exit(1)


if __name__ == "__main__":
    main()
