#!/usr/bin/env python3
"""kt-diff — Translation status analysis.

Usage:
    kt-diff [--status] [--dir DIR] [--detail FILE] [--json]
            [--page N] [--per-page N] [--type outdated|missing]
            [--dirs [DIR]] [--search KEYWORD] [--sort behind|size]

Options:
    --status         Global overview (default)
    --dir DIR        Limit to a subdirectory
    --detail FILE    Show detailed diff for a specific file
    --json           Output JSON
    --page N         Page number (default: 1)
    --per-page N     Items per page (default: 10)
    --type TYPE      Filter: outdated or missing (default: outdated)
    --dirs [DIR]     Show directory tree with file counts; optionally drill into DIR
    --search KEYWORD Fuzzy search file paths by keyword
    --sort ORDER     Sort: behind (default for outdated), size (line count, small first)
"""

import json
import sys
from collections import Counter
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from lib.diff import get_status_cached, get_detail
from lib.project import en_doc_dir


def _line_count(rel_path):
    """Count lines of an English doc file. Returns 0 on error."""
    try:
        return sum(1 for _ in open(en_doc_dir() / rel_path, "rb"))
    except OSError:
        return 0


def _get_arg(args, flag, default=None):
    if flag in args:
        idx = args.index(flag)
        if idx + 1 < len(args) and not args[idx + 1].startswith("--"):
            return args[idx + 1]
    return default


def _get_flag_with_optional_arg(args, flag):
    """Return (present, arg). arg is None if flag has no argument."""
    if flag not in args:
        return False, None
    idx = args.index(flag)
    if idx + 1 < len(args) and not args[idx + 1].startswith("--"):
        return True, args[idx + 1]
    return True, None


def _dirs_mode(result, file_type, parent_dir, page, per_page, use_json):
    """Show directory tree with file counts, paginated."""
    if file_type == "missing":
        paths = result.get("missing", [])
    else:
        paths = [f["file"] for f in result["files"] if f["status"] == "outdated"]

    # Filter to parent_dir if given
    if parent_dir:
        prefix = parent_dir.rstrip("/") + "/"
        paths = [p for p in paths if p.startswith(prefix)]

    # Group by next directory level
    dirs = Counter()
    files_here = []
    for p in paths:
        if parent_dir:
            rel = p[len(parent_dir.rstrip("/")) + 1:]
        else:
            rel = p
        parts = rel.split("/")
        if len(parts) == 1:
            files_here.append(p)
        else:
            dirs[parts[0]] += 1

    # Build combined list: directories first (sorted by count desc), then files
    sorted_dirs = sorted(dirs.items(), key=lambda x: -x[1])
    all_entries = []
    for d, c in sorted_dirs:
        full = f"{parent_dir.rstrip('/')}/{d}" if parent_dir else d
        all_entries.append({"dir": full, "name": d, "count": c})
    outdated_map = {}
    if file_type != "missing":
        outdated_map = {f["file"]: f for f in result["files"] if f["status"] == "outdated"}
    for f in files_here:
        entry = {"file": f}
        if f in outdated_map:
            entry["commits_behind"] = outdated_map[f]["commits_behind"]
        all_entries.append(entry)

    total = len(all_entries)
    total_pages = (total + per_page - 1) // per_page if total else 1
    start = (page - 1) * per_page
    page_items = all_entries[start:start + per_page]

    if use_json:
        print(json.dumps({
            "type": file_type,
            "parent": parent_dir or "",
            "entries": page_items,
            "pagination": {
                "page": page,
                "per_page": per_page,
                "total": total,
                "total_pages": total_pages,
            },
        }, indent=2, ensure_ascii=False))
    else:
        label = "未翻译" if file_type == "missing" else "待更新"
        location = parent_dir or "."
        print(f"{label}文件 — 目录: {location}  (第 {page}/{total_pages} 页, 共 {total} 项)\n")
        for i, entry in enumerate(page_items, start=start + 1):
            if "dir" in entry:
                print(f"  {i:3d}. {entry['name']}/  ({entry['count']} 个)")
            elif entry.get("commits_behind") is not None:
                print(f"  {i:3d}. {entry['file']}  ({entry['commits_behind']} behind)")
            else:
                print(f"  {i:3d}. {entry['file']}")
        if not page_items:
            print("  （无文件）")
        if total_pages > 1:
            dirs_flag = f"--dirs {parent_dir}" if parent_dir else "--dirs"
            nav = []
            if page > 1:
                nav.append(f"上一页: kt-diff {dirs_flag} --type {file_type} --page {page - 1}")
            if page < total_pages:
                nav.append(f"下一页: kt-diff {dirs_flag} --type {file_type} --page {page + 1}")
            print(f"\n  → {'  |  '.join(nav)}")


def _search_mode(result, file_type, keyword, use_json):
    """Fuzzy search file paths by keyword."""
    keyword_lower = keyword.lower()
    parts = keyword_lower.split()

    if file_type == "missing":
        candidates = [{"file": f, "commits_behind": None} for f in result.get("missing", [])]
    else:
        candidates = [f for f in result["files"] if f["status"] == "outdated"]

    # Match: all parts must appear in the file path (order-independent)
    matches = []
    for item in candidates:
        path_lower = item["file"].lower()
        if all(p in path_lower for p in parts):
            matches.append(item)

    if use_json:
        print(json.dumps({
            "type": file_type,
            "keyword": keyword,
            "total": len(matches),
            "matches": matches,
        }, indent=2, ensure_ascii=False))
    else:
        label = "未翻译" if file_type == "missing" else "待更新"
        print(f"搜索 \"{keyword}\" — {label}文件中找到 {len(matches)} 个:\n")
        if not matches:
            print("  （无匹配）")
        else:
            for i, item in enumerate(matches, 1):
                if item.get("commits_behind") is not None:
                    print(f"  {i:3d}. {item['file']}  ({item['commits_behind']} behind)")
                else:
                    print(f"  {i:3d}. {item['file']}")


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__.strip()); return
    use_json = "--json" in args
    file_type = _get_arg(args, "--type", "outdated")

    if "--detail" in args:
        file_path = _get_arg(args, "--detail")
        if not file_path:
            print("错误: --detail 需要指定文件路径", file=sys.stderr)
            sys.exit(1)
        result = get_detail(file_path)
        if use_json:
            print(json.dumps(result, indent=2, ensure_ascii=False))
        else:
            if "error" in result:
                print(result["error"])
                sys.exit(1)
            print(f"文件: {result['file']}")
            print(f"中文最后更新: {result.get('zh_date', '?')} (基准 {result.get('en_base_commit', '?')})")
            print(f"英文变更: {result['changes_count']} 个 commit")
            if result["changes"]:
                print("\n变更列表:")
                for c in result["changes"]:
                    print(f"  {c}")
            if result["diff"]:
                print(f"\nDiff:\n{result['diff']}")
        sys.exit(0)

    # --dirs mode
    has_dirs, dirs_arg = _get_flag_with_optional_arg(args, "--dirs")
    if has_dirs:
        page = int(_get_arg(args, "--page", "1"))
        per_page = int(_get_arg(args, "--per-page", "10"))
        result = get_status_cached()
        _dirs_mode(result, file_type, dirs_arg, page, per_page, use_json)
        sys.exit(0)

    # --search mode
    search_kw = _get_arg(args, "--search")
    if search_kw:
        result = get_status_cached()
        _search_mode(result, file_type, search_kw, use_json)
        sys.exit(0)

    # --status or --dir
    subdir = _get_arg(args, "--dir")
    page = int(_get_arg(args, "--page", "1"))
    per_page = int(_get_arg(args, "--per-page", "10"))
    sort_by = _get_arg(args, "--sort", "behind")

    result = get_status_cached(subdir)

    # Prepare items based on type
    if file_type == "missing":
        raw_items = result.get("missing", [])
    else:
        raw_items = [f for f in result["files"] if f["status"] == "outdated"]

    # Sort by size if requested — enrich items with line counts
    if sort_by == "size":
        if file_type == "missing":
            sized = [{"file": f, "lines": _line_count(f)} for f in raw_items]
        else:
            sized = [dict(**f, lines=_line_count(f["file"])) for f in raw_items]
        sized.sort(key=lambda x: x["lines"])
        items = sized
        sort_label = "按行数"
    else:
        if file_type == "missing":
            items = [{"file": f} for f in raw_items]
        else:
            items = raw_items
        sort_label = "按落后程度"

    total = len(items)
    total_pages = (total + per_page - 1) // per_page if total else 1
    start = (page - 1) * per_page
    page_items = items[start:start + per_page]

    if use_json:
        out = {
            "head": result["head"],
            "total_english": result["total_english"],
            "total_zh": result["total_zh"],
            "coverage": result["coverage"],
            "files": page_items if file_type != "missing" else [],
            "missing": page_items if file_type == "missing" else [],
            "pagination": {
                "type": file_type,
                "sort": sort_by,
                "page": page,
                "per_page": per_page,
                "total": total,
                "total_pages": total_pages,
            },
        }
        print(json.dumps(out, indent=2, ensure_ascii=False))
    else:
        print(f"HEAD: {result['head']}")
        missing_count = len(result.get("missing", []))
        outdated_count = sum(1 for f in result["files"] if f["status"] == "outdated")
        print(f"英文文件: {result['total_english']}  中文文件: {result['total_zh']}  "
              f"覆盖率: {result['coverage']}%  待更新: {outdated_count}  未翻译: {missing_count}")

        label = "未翻译文件" if file_type == "missing" else "待更新翻译"

        if page_items:
            print(f"\n{label} · {sort_label} (第 {page}/{total_pages} 页, 共 {total} 个):")
            for i, item in enumerate(page_items, start=start + 1):
                f = item["file"] if isinstance(item.get("file"), str) else item.get("file", "")
                lines_str = f"  ({item['lines']} 行)" if "lines" in item else ""
                behind_str = ""
                if item.get("commits_behind") is not None:
                    behind_str = f"  {item['commits_behind']} behind"
                    if item.get("en_base_commit"):
                        behind_str += f"  ({item['en_base_commit']} → {item['en_head_commit']})"
                print(f"  {i:3d}. {f}{lines_str}{behind_str}")
            if total_pages > 1:
                sort_flag = f" --sort {sort_by}" if sort_by != "behind" else ""
                nav = []
                if page > 1:
                    nav.append(f"上一页: kt-diff --type {file_type}{sort_flag} --page {page - 1}")
                if page < total_pages:
                    nav.append(f"下一页: kt-diff --type {file_type}{sort_flag} --page {page + 1}")
                print(f"\n  → {'  |  '.join(nav)}")


if __name__ == "__main__":
    main()
